      "parameters": {
        "jsCode": "\nconst firstItem = $input.first() || {};\nconst errorObj = firstItem.error || {};\nconst cause = errorObj.cause || {};\nconst jsonObj = firstItem.json || {};\nconst nestedError = jsonObj.error || {};\nconst nestedCause = nestedError.cause || {};\n\nconst pgCode = String(\n  cause.code || errorObj.code || \n  nestedCause.code || nestedError.code || \n  jsonObj.code || ''\n);\n\nconst rawMessage = String(\n  jsonObj.message || \n  cause.message || errorObj.message || errorObj.description || \n  nestedCause.message || nestedError.message || nestedError.description || \n  'Error desconocido'\n);\n\nlet status = 500;\nlet errorType = 'Internal Server Error';\nlet message = rawMessage;\nlet code = 'DB_ERROR';\n\nif (pgCode === '23505' || rawMessage.includes('unique constraint')) {\n  // Unique constraint violation\n  status = 409;\n  errorType = 'Conflict';\n  code = 'DUPLICATE_ENTRY';\n  if (rawMessage.toLowerCase().includes('email')) {\n    message = 'El correo electrónico ya se encuentra registrado.';\n    code = 'EMAIL_ALREADY_EXISTS';\n  } else {\n    const match = rawMessage.match(/unique constraint \"(.+?)\"/i);\n    message = match\n      ? `Ya existe un registro que viola la restricción: ${match[1]}.`\n      : 'Ya existe un registro con esos datos.';\n  }\n} else if (pgCode === '23502' || rawMessage.includes('not-null constraint') || rawMessage.includes('violates not-null')) {\n  // NOT NULL violation\n  status = 422;\n  errorType = 'Unprocessable Entity';\n  code = 'MISSING_REQUIRED_FIELD';\n  const match = rawMessage.match(/column \"(.+?)\"/);\n  const field = match ? match[1] : 'desconocido';\n  message = `El campo \"${field}\" es obligatorio y no puede estar vacío.`;\n} else if (pgCode === '23503' || rawMessage.includes('foreign key constraint')) {\n  // Foreign key violation\n  status = 409;\n  errorType = 'Conflict';\n  code = 'FOREIGN_KEY_VIOLATION';\n  message = 'El registro referenciado no existe o ha sido eliminado.';\n} else if (pgCode === '23514' || rawMessage.includes('check constraint')) {\n  // Check constraint violation\n  status = 422;\n  errorType = 'Unprocessable Entity';\n  code = 'CHECK_VIOLATION';\n  message = 'Los datos enviados no cumplen las restricciones requeridas.';\n} else if (rawMessage.includes('invalid input syntax for type date')) {\n  status = 422;\n  errorType = 'Unprocessable Entity';\n  code = 'INVALID_DATE_FORMAT';\n  message = 'El formato de fecha introducido no es válido o está vacío.';\n} else if (rawMessage.includes('invalid input syntax')) {\n  status = 422;\n  errorType = 'Unprocessable Entity';\n  code = 'INVALID_INPUT_FORMAT';\n  message = 'Uno de los campos introducidos tiene un formato incorrecto (ej: texto en lugar de número).';\n}\n\nreturn [{ json: { status, error: errorType, message, code } }];\n"
