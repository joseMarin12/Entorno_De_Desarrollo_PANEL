        "jsCode": "const worker = $input.item.json;\nconst body = $('Webhook Trabajadores1').first().json.body;\nconst docs = body.documentos || [];\nlet results = [];\nfor (let d of docs) {\n  results.push({\n    json: {\n      body: {\n        action: 'uploadDocumento',\n        trabajadorId: worker.id,\n        origen: d.origen,\n        tipoId: d.tipoId,\n        nombre: d.nombre,\n        descripcion: d.descripcion,\n        base64: d.base64,\n        trabajadorData: worker\n      }\n    }\n  });\n}\nreturn results;"
