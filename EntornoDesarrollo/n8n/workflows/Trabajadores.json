    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT f.id, f.curso, ef.nombre AS estado, af.nombre AS area, mf.nombre AS modalidad, f.fecha_inicio, f.fecha_fin, ft.asistencia, ft.eficacia FROM formacion_trabajador ft JOIN formacion f ON f.id=ft.id_formacion LEFT JOIN estado_formacion ef ON ef.id=f.id_estado LEFT JOIN area_formacion af ON af.id=f.id_area LEFT JOIN modalidad_formacion mf ON mf.id=f.id_modalidad WHERE ft.id_trabajador=$1 ORDER BY f.fecha_inicio DESC;",
        "options": { "queryReplacement": "={{ [$json.body.trabajadorId] }}" }
      },
