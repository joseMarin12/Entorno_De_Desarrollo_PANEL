      "parameters": {
        "operation": "executeQuery",
        "query": "WITH upd AS (UPDATE trabajador SET activo = NOT activo WHERE id = $1 RETURNING *) SELECT u.*, p.provincia AS provincia_nombre, l.localidad AS localidad_nombre, CONCAT(s.nombre,' ',s.primer_apellido) AS seleccionador_nombre FROM upd u LEFT JOIN provincia p ON u.id_provincia=p.id LEFT JOIN localidad l ON u.id_localidad=l.id LEFT JOIN seleccionadores s ON u.id_seleccionadores=s.id;",
        "options": { "queryReplacement": "={{ [$json.body.trabajadorId] }}" }
