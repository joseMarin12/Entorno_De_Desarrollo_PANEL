    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT a.id, a.fecha_ini, a.fecha_fin, a.tarifa, e.nombre_empresa AS empresa_nombre, CONCAT(c.nombre,' ',c.primer_apellido) AS comercial_nombre, CASE WHEN a.fecha_fin IS NULL OR a.fecha_fin > NOW() THEN true ELSE false END AS activo FROM asignacion a JOIN empresa e ON e.id=a.id_empresa LEFT JOIN comerciales c ON c.id=a.id_comerciales WHERE a.id_trabajador=$1 ORDER BY a.fecha_ini DESC;",
        "options": { "queryReplacement": "={{ [$json.body.trabajadorId] }}" }
      },
      "id": "d73dbf29-f81c-4a6f-9e92-3d6bb58f780b", "name": "SQL: Get Asignaciones By Trabajador", "type": "n8n-nodes-base.postgres", "typeVersion": 2.6, "position": [3104, 4800],
