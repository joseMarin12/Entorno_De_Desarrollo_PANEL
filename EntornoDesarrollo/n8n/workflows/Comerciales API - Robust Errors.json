    {
      "parameters": {
        "jsCode": "const filters = $input.item.json.body.filters || {};\nconst conditions = [];\nconst params = [];\nlet paramIndex = 1;\n\nlet query = 'SELECT id, nombre, primer_apellido, segundo_apellido, telefono, email, activo, created_at, updated_at FROM comerciales WHERE 1=1';\n\nif (filters.searchText && typeof filters.searchText === 'string' && filters.searchText.trim() !== '') {\n  conditions.push(`(CONCAT(nombre, ' ', primer_apellido, ' ', COALESCE(segundo_apellido,'')) ILIKE $${paramIndex} OR email ILIKE $${paramIndex})`);\n  params.push(`%${filters.searchText}%`);\n  paramIndex++;\n}\n\nif (filters.status !== undefined && filters.status !== null && filters.status !== '') {\n  conditions.push(`activo = $${paramIndex}`);\n  params.push(filters.status);\n  paramIndex++;\n}\n\nif (conditions.length > 0) {\n  query += ' AND ' + conditions.join(' AND ');\n}\n\nquery += ' ORDER BY created_at DESC';\n\nreturn [{ json: { query, params } }];"
      },
