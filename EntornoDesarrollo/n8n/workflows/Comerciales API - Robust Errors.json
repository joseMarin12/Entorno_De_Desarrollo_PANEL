    {
      "parameters": {
        "jsCode": "const src = $json || {};\nconst errObj = src.error ?? src;\nconst rawMessage = String(\n  errObj?.message ??\n  errObj?.description ??\n  errObj?.error?.message ??\n  errObj?.cause?.message ??\n  src?.message ??\n  'Error de base de datos'\n).trim();\nconst detail = String(\n  errObj?.detail ??\n  errObj?.error?.detail ??\n  errObj?.cause?.detail ??\n  ''\n).trim();\nconst code = String(\n  errObj?.code ??\n  errObj?.error?.code ??\n  errObj?.cause?.code ??\n  errObj?.originalError?.code ??\n  errObj?.cause?.originalError?.code ??\n  ''\n).trim();\nconst isDuplicate = code === '23505' ||\n  rawMessage.toLowerCase().includes('duplicate key') ||\n  rawMessage.toLowerCase().includes('unique constraint') ||\n  rawMessage.toLowerCase().includes('already exists') ||\n  detail.toLowerCase().includes('already exists');\nconst message = isDuplicate ? 'El email ya existe.' : rawMessage;\nreturn [{\n  json: {\n    success: false,\n    message,\n    code: isDuplicate ? '23505' : code,\n    detail,\n    isDuplicate\n  }\n}];"
      },
