    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  d.id,\n  d.nombre_fichero,\n  td.nombre AS tipo_nombre,\n  d.id_tipo_documento AS tipo_id,\n  d.descripcion,\n  d.created_at AS fecha_creacion,\n  CASE WHEN f.id IS NULL THEN NULL ELSE json_build_object(\n    'id', f.id,\n    'estado', f.estado,\n    'fecha_asignacion', d.created_at,\n    'sinatura_id', f.sinatura_id,\n    'requiere_firma_rrhh', f.requiere_firma_rrhh,\n    'email_segundo_firmante', f.email_segundo_firmante,\n    'motivo', f.motivo,\n    'fecha_envio', f.fecha_envio,\n    'fecha_firma_trabajador', f.fecha_firma_trabajador,\n    'fecha_firma_rrhh', f.fecha_firma_rrhh,\n    'fecha_completado', f.fecha_completado\n  ) END AS firma\nFROM documento d\nLEFT JOIN tipo_documento td ON td.id = d.id_tipo_documento\nLEFT JOIN firma f ON f.id_documento = d.id\nWHERE d.id_trabajador = $1\nORDER BY d.created_at DESC;",
        "options": {
          "queryReplacement": "={{ [$json.body.trabajadorId] }}"
        }
      },
      "id": "22139767-b34c-4af9-9717-de74554eb9ad",
      "name": "SQL: Get Documentos",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "alwaysOutputData": true,
      "position": [
        0,
        -160
      ],
      "credentials": {
        "postgres": {
          "id": "AUTOPOSTGRESCRED01",
          "name": "Postgres account"
        }
