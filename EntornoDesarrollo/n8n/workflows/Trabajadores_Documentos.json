    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT d.id, d.id_tipoDoc, t.tipo AS tipo_nombre, d.nombre_fichero, ENCODE(d.doc, 'base64') AS doc, d.descripcion, d.created_at as fecha_creacion FROM documentacion d LEFT JOIN tipoDoc t ON t.id = d.id_tipoDoc WHERE d.id_trabajador = $1 ORDER BY d.created_at DESC;",
        "options": {
          "queryReplacement": "={{ [$json.body.trabajadorId] }}"
