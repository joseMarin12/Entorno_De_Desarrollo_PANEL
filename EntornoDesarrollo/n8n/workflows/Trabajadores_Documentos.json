      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE documentacion SET descripcion = COALESCE($1, descripcion), doc = CASE WHEN $2 != '' THEN DECODE($2, 'base64') ELSE doc END, nombre_fichero = CASE WHEN $3 != '' THEN $3 ELSE nombre_fichero END, updated_at = CURRENT_TIMESTAMP WHERE id = $4 RETURNING id;",
