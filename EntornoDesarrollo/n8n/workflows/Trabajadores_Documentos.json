    {
      "parameters": {
        "jsCode": "// Normaliza el payload de creación de documento. El front manda `createDocumento` con todo\n// bajo `body.documentoData`; el alta al crear un trabajador manda `uploadDocumento` con los\n// campos planos en `body`. Unificamos ambas formas y convertimos los ids a enteros.\n// Procesa TODOS los items: soporta varios documentos en una misma alta de trabajador.\nconst toInt = (v) => (v === null || v === undefined || v === '') ? null : parseInt(v, 10);\nreturn $input.all().map((item) => {\n  const b = item.json.body || {};\n  const d = b.documentoData || b;\n  return {\n    json: {\n      id_trabajador: toInt(d.id_trabajador ?? d.trabajadorId ?? b.trabajadorId),\n      tipoId: toInt(d.tipoId),\n      descripcion: d.descripcion || '',\n      requiere_firma: d.requiere_firma === true,\n      fileName: d.fileName || d.nombre || null,\n      base64: d.base64 || ''\n    }\n  };\n});"
      },
      "id": "c0343683-171b-4a5d-a620-2dd56fee0383",
      "name": "JS: Normalizar Create",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -140,
        80
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Alta de documento (archivo subido por el usuario). Inserta documento + su contenido y,\n-- si requiere firma, crea el registro de firma en PENDIENTE_ENVIO (aún no se envía a Sinatura;\n-- eso lo hace el Motor Firmas con la acción enviarFirma).\nWITH nuevo_doc AS (\n  INSERT INTO documento (id_trabajador, id_tipo_documento, nombre_fichero, descripcion, requiere_firma)\n  VALUES ($1, $2, $3, $4, $5)\n  RETURNING id\n),\narchivo AS (\n  INSERT INTO documento_archivo (id_documento, contenido_b64)\n  SELECT id, $6 FROM nuevo_doc\n  RETURNING id_documento\n),\nnueva_firma AS (\n  INSERT INTO firma (id_documento, estado, requiere_firma_rrhh)\n  SELECT id, 'PENDIENTE_ENVIO', $7 FROM nuevo_doc WHERE $5 = true\n  RETURNING id_documento\n)\nSELECT id FROM nuevo_doc;",
        "options": {
          "queryReplacement": "={{ [$json.id_trabajador, $json.tipoId || null, $json.fileName || 'documento.pdf', $json.descripcion || '', $json.requiere_firma === true, $json.base64 || '', false] }}"
        }
      },
      "id": "c3d4e5f6-3333-4444-5555-666677778888",
      "name": "SQL: Insert Manual",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        360,
        160
      ],
      "credentials": {
        "postgres": {
          "id": "AUTOPOSTGRESCRED01",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Actualiza descripción y, opcionalmente, nombre y contenido del archivo.\n-- El reemplazo de archivo solo ocurre si llega base64 (el front lo bloquea si hay firma).\nWITH upd AS (\n  UPDATE documento SET\n    descripcion = COALESCE($2, descripcion),\n    nombre_fichero = CASE WHEN $3 <> '' THEN $3 ELSE nombre_fichero END,\n    updated_at = NOW()\n  WHERE id = $1\n  RETURNING id\n),\nupd_arch AS (\n  UPDATE documento_archivo SET contenido_b64 = $4, updated_at = NOW()\n  WHERE id_documento = $1 AND $4 <> ''\n  RETURNING id_documento\n)\nSELECT id FROM upd;",
        "options": {
          "queryReplacement": "={{ [($json.body.documentoData||{}).id, ($json.body.documentoData||{}).descripcion || null, ($json.body.documentoData||{}).fileName || '', ($json.body.documentoData||{}).base64 || ''] }}"
        }
      },
