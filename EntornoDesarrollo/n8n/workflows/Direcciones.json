        "jsCode": "const id = $input.item.json.id;\n\nreturn [{\n  json: {\n    query: `\n      SELECT \n      d.id,\n      d.direccion,\n      d.codigo_postal,\n      d.id_localidad,\n      d.id_empresa,\n      d.activo,\n      d.created_at,\n      l.localidad,\n      l.id_provincia,\n      p.provincia,\n      p.id_pais,\n      pa.pais\n      FROM direccion_empresa d \n      LEFT JOIN localidad l ON l.id = d.id_localidad\n      LEFT JOIN provincia p ON p.id = l.id_provincia\n      LEFT JOIN pais pa ON pa.id = p.id_pais \n      WHERE d.id = $1\n      GROUP BY d.id, d.direccion, d.codigo_postal, d.id_localidad, d.id_empresa,\n      d.activo, d.created_at, l.localidad, l.id_provincia, p.provincia,\n      p.id_pais, pa.pais\n    `,\n    params: String(id)\n  }\n}];"
