    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\n\nconst fields = ['direccion', 'codigo_postal', 'id_empresa', 'id_localidad', 'activo'];\nconst values = [body.direccionData.direccion, body.direccionData.codigoPostal, body.direccionData.id_empresa, body.direccionData.id_localidad, body.direccionData.activo];\n\nconst placeholders = values.map((_, i) => `$${i + 1}`).join(', ');\n\nreturn [{\n  json: {\n    query: `INSERT INTO direccion_empresa (${fields.join(', ')})\n            VALUES (${placeholders})\n            RETURNING id, direccion, codigo_postal, id_empresa, id_localidad, activo, created_at`,\n    params: values.join(',')\n  }\n}];"
