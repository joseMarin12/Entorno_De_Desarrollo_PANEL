    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\nconst cd = body.comercialData || {};\n\nconst fields = ['nombre', 'primer_apellido', 'segundo_apellido', 'telefono', 'email', 'activo'];\nconst values = [\n  cd.nombre ?? null,\n  cd.primer_apellido ?? null,\n  cd.segundo_apellido ?? null,\n  cd.telefono ?? null,\n  cd.email ?? null,\n  cd.activo !== undefined ? cd.activo : true\n];\n\nconst placeholders = values.map((_, i) => `$${i + 1}`).join(', ');\n\nreturn [{\n  json: {\n    query: `INSERT INTO comerciales (${fields.join(', ')}) VALUES (${placeholders}) RETURNING *`,\n    params: values\n  }\n}];"
      },
