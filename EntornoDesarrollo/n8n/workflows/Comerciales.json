    {
      "parameters": {
        "jsCode": "const filters = $input.item.json.body.filters || {};\nconst page = $input.item.json.body.page || 1;\nconst limit = $input.item.json.body.limit || 10;\nconst offset = (page - 1) * limit;\n\nconst conditions = [];\nconst params = [];\nlet paramIndex = 1;\n\nlet query = `SELECT c.id, c.nombre, c.primer_apellido, c.segundo_apellido, c.telefono, c.email, c.activo, c.created_at, c.updated_at,\nCOUNT(*) OVER() AS total_filtered,\n(SELECT COUNT(*) FROM comerciales) AS stats_total,\n(SELECT COUNT(*) FROM comerciales WHERE activo = true) AS stats_activos,\n(SELECT COUNT(*) FROM comerciales WHERE activo = false) AS stats_inactivos\nFROM comerciales c\nWHERE 1=1`;\n\nif (filters.searchText && filters.searchText.trim() !== '') {\n  conditions.push(`(c.nombre ILIKE $${paramIndex} OR c.primer_apellido ILIKE $${paramIndex} OR c.email ILIKE $${paramIndex})`);\n  params.push(`%${filters.searchText}%`);\n  paramIndex++;\n}\n\nif (filters.status && filters.status.trim() !== '') {\n  if (filters.status === 'true' || filters.status === 'activo' || filters.status === 'activos') {\n    conditions.push('c.activo = true');\n  } else if (filters.status === 'false' || filters.status === 'baja' || filters.status === 'inactivos') {\n    conditions.push('c.activo = false');\n  }\n}\n\nif (conditions.length > 0) {\n  query += ' AND ' + conditions.join(' AND ');\n}\n\nquery += ' ORDER BY c.id ASC';\nquery += ` LIMIT ${limit} OFFSET ${offset}`;\n\nreturn [{\n  json: {\n    query: query,\n    params: params.join(',')\n  }\n}];"
      },
