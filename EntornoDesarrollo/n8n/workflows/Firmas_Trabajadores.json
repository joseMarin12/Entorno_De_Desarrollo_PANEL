    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || {};\nconst recipients = [];\n\n// 1. Trabajador\nrecipients.push({\n  name: body.trabajador_nombre,\n  email: body.trabajador_email,\n  type: \"signer\",\n  delivery_type: \"url\" \n});\n\n// 2. RRHH (Si aplica)\nif (body.requiere_rrhh) {\n  recipients.push({\n    name: \"Recursos Humanos\",\n    email: body.rrhh_email || \"rrhh@sgtech.tech\",\n    type: \"signer\",\n    delivery_type: \"url\"\n  });\n}\n\nreturn [{ json: { recipients, body } }];"
      },
      "id": "4b7b2fb0-2ed5-4303-ac80-cf5272a9e3cb",
