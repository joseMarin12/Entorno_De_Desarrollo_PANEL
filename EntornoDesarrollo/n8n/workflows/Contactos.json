        "jsCode": "const body = $input.item.json.body;\nconst d = body.contactoData;\nconst fields = ['nombre', 'primer_apellido', 'cargo', 'email', 'telefono', 'id_empresa', 'activo'];\nconst params = [d.nombre, d.primer_apellido, d.cargo, d.email, d.telefono, d.id_empresa, d.activo];\nconst placeholders = params.map((_, i) => `$${i + 1}`).join(', ');\nreturn [{ json: {\n  query: `INSERT INTO contacto_empresa (${fields.join(', ')}) VALUES (${placeholders}) RETURNING id, nombre, primer_apellido, cargo, email, telefono, id_empresa, activo, created_at`,\n  params\n} }];"
      },
