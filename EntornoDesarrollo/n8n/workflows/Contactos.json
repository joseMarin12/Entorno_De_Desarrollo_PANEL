    {
      "parameters": {
        "jsCode": "const filters = $input.item.json.body.filters || {};\nconst idEmpresa = $input.item.json.body.idEmpresa;\nconst page = $input.item.json.body.page || 1;\nconst limit = $input.item.json.body.limit || 10;\nconst offset = (page - 1) * limit;\nconst conditions = [];\nconst params = [idEmpresa];\nlet paramIndex = 2;\n\nlet query = `SELECT c.id, c.nombre, c.primer_apellido, c.cargo, c.email, c.telefono, c.id_empresa, c.activo, c.created_at,\n  COUNT(*) OVER() AS total_count,\n  COUNT(*) FILTER (WHERE c.activo = true) OVER() AS total_activos,\n  COUNT(*) FILTER (WHERE c.activo = false) OVER() AS total_inactivos\nFROM contacto_empresa c\nWHERE c.id_empresa = $1`;\n\nif (filters.searchText && filters.searchText.trim() !== '') {\n  conditions.push(`(c.nombre ILIKE $${paramIndex} OR c.primer_apellido ILIKE $${paramIndex})`);\n  params.push(`%${filters.searchText}%`);\n  paramIndex++;\n}\n\nif (filters.status && filters.status.trim() !== '') {\n  if (filters.status === 'activo') conditions.push(`c.activo = true`);\n  else if (filters.status === 'baja') conditions.push(`c.activo = false`);\n}\n\nif (conditions.length > 0) query += ' AND ' + conditions.join(' AND ');\nquery += ' ORDER BY c.created_at ASC';\nquery += ` LIMIT ${limit} OFFSET ${offset}`;\n\nreturn [{ json: { query, params } }];"
      },
