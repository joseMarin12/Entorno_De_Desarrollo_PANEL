    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\n\nconst fields = ['nombre', 'primer_apellido', 'telefono', 'email', 'cargo', 'id_empresa'];\nconst values = [body.contactoData.nombre, body.contactoData.primer_apellido, body.contactoData.telefono, body.contactoData.email, body.contactoData.cargo, body.contactoData.id_empresa];\n\nconst placeholders = values.map((_, i) => `$${i + 1}`).join(', ');\n\nreturn [{\n  json: {\n    query: `INSERT INTO contacto_empresa (${fields.join(', ')})\n            VALUES (${placeholders})\n            RETURNING id, nombre, primer_apellido, telefono, email, cargo, id_empresa`,\n    params: values\n  }\n}];"
      },
