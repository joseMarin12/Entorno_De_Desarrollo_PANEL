    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\n\nconst fields = [\u0027nombre_empresa\u0027, \u0027razon_social\u0027, \u0027cif\u0027, \u0027id_tipo_empresa\u0027, \u0027activo\u0027];\nconst values = [body.empresaData.nombre, body.empresaData.razonSocial, body.empresaData.cif, body.empresaData.id_tipo_empresa, body.empresaData.activo];\n\nif (body.empresaData.id_comerciales !== null \u0026\u0026 body.empresaData.id_comerciales !== undefined) {\n  fields.push(\u0027id_comerciales\u0027);\n  values.push(body.empresaData.id_comerciales);\n}\n\nconst placeholders = values.map((_, i) =\u003e `$${i + 1}`).join(\u0027, \u0027);\n\nreturn [{\n  json: {\n    query: `INSERT INTO empresa (${fields.join(\u0027, \u0027)})\n            VALUES (${placeholders})\n            RETURNING id, nombre_empresa AS nombre, razon_social, cif, id_tipo_empresa, id_comerciales, activo, created_at`,\n    params: values.join(\u0027,\u0027)\n  }\n}];"
      },
