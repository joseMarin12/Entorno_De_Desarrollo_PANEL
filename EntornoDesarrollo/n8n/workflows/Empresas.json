    {
      "parameters": {
        "content": "## Empresas Management API\n\n**Endpoint:** POST /webhook/gestion-empresas\n\n**Actions:**\n- getEmpresas: Obtiene las empresas clientes\n- createEmpresa: creaciÃ³n de empresa cliente\n- updateEmpresa: actualizar empresa cliente mediante ID\n- toggleEmpresaStatus: dar de baja a empresa cliente mediante ID\n- getTiposEmpresa: obtiene los tipos de las empresas",
        "height": 312,
        "width": 340,
        "color": 4
      },
      "id": "86ca3a50-c39c-4f86-b591-c4183055177c",
      "name": "Sticky Note 7ebaaad5",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -928,
        256
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "gestion-empresas",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "e00f7ff6-370b-4bf9-a1d1-b7c083702a08",
      "name": "GestiÃ³n Empresas API",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        -448,
        384
      ],
      "webhookId": "0105c6ba-d2f2-478a-87b6-cf65f658184e"
    },
    {
      "parameters": {
        "jsCode": "const filters = $input.item.json.body.filters || {};\nconst conditions = [];\nconst params = [];\nlet paramIndex = 1;\n\nlet query = `SELECT e.id, e.nombre_empresa AS nombre, e.razon_social, e.cif, e.created_at, e.activo, e.id_tipo_empresa,\nt.tipo_empresa AS tipo, e.id_comerciales, COUNT(DISTINCT d.id) AS direcciones, \nCOUNT(DISTINCT c.id) AS contactos \nFROM empresa e \nLEFT JOIN tipo_empresa t ON t.id = e.id_tipo_empresa \nLEFT JOIN direccion_empresa d ON d.id_empresa = e.id \nLEFT JOIN contacto_empresa c ON c.id_empresa = e.id \nWHERE 1=1`;\n\nif (filters.searchText \u0026\u0026 filters.searchText.trim() !== \u0027\u0027) {\n  conditions.push(`(e.nombre_empresa ILIKE $${paramIndex})`);\n  params.push(`%${filters.searchText}%`);\n  paramIndex++;\n}\n\nif (filters.tipo \u0026\u0026 filters.tipo.trim() !== \u0027\u0027) {\n  conditions.push(`t.tipo_empresa = $${paramIndex}`);\n  params.push(filters.tipo);\n  paramIndex++;\n}\n\nif (conditions.length \u003e 0) {\n  query += \u0027 AND \u0027 + conditions.join(\u0027 AND \u0027);\n}\n\nquery += \u0027 GROUP BY e.id, e.nombre_empresa, t.tipo_empresa\u0027;\nquery += \u0027 ORDER BY e.created_at ASC\u0027;\n\nreturn [{\n  json: {\n    query: query,\n    params: params.join(\u0027,\u0027)\n  }\n}];"
      },
