    {
      "parameters": {
        "jsCode": "const id = $input.item.json.id;\n\nreturn [{\n  json: {\n    query: `\n      SELECT \n        e.id,\n        e.nombre_empresa        AS nombre,\n        e.razon_social,\n        e.cif,\n        e.activo,\n        e.id_tipo_empresa,\n        t.tipo_empresa          AS tipo,\n        e.id_comerciales,\n        NULLIF(CONCAT(c.nombre, \u0027 \u0027, c.primer_apellido), \u0027 \u0027) AS comercial,\n        COUNT(DISTINCT d.id)    AS direcciones,\n        COUNT(DISTINCT co.id)   AS contactos\n      FROM empresa e\n      LEFT JOIN tipo_empresa t  ON t.id = e.id_tipo_empresa\n      LEFT JOIN comerciales c     ON c.id = e.id_comerciales\n      LEFT JOIN direccion_empresa d  ON d.id_empresa = e.id\n      LEFT JOIN contacto_empresa co  ON co.id_empresa = e.id\n      WHERE e.id = $1\n      GROUP BY e.id, t.tipo_empresa, c.nombre, c.primer_apellido\n    `,\n    params: String(id)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
