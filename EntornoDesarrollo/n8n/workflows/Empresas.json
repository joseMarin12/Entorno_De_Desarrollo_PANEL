        "jsCode": "const body   = $input.item.json.body;\nconst data   = body.empresaData;\nconst params = [];\nlet paramIndex = 1;\n\nconst tipoQuery    = `SELECT id FROM tipo_empresa WHERE tipo_empresa = $1`;\nconst comercialQuery = data.comercial \n  ? `SELECT id FROM comerciales WHERE CONCAT(nombre, ' ', primer_apellido) = $1`\n  : null;\n\nreturn [{\n  json: {\n    nombre:      data.nombre,\n    razonSocial: data.razonSocial,\n    cif:         data.cif,\n    tipo:        data.tipo,\n    comercial:   data.comercial || null,\n    activo:      data.activo,\n    tipoQuery,\n    comercialQuery,\n  }\n}];"
