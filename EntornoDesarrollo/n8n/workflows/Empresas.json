    {
      "parameters": {
        "jsCode": "const data       = $('Build Import Empresas Query').first().json;\nconst tipoResult = $('Resolve Tipo').first().json;\n\nlet idComercial = null;\ntry {\n  const comResult = $('Resolve Comercial').first().json;\n  idComercial = comResult?.id ?? null;\n} catch (e) {\n  idComercial = null;\n}\n\nconst idTipo = tipoResult?.id ?? null;\nif (!idTipo) throw new Error(`Tipo \"${data.tipo}\" no encontrado`);\n\nreturn [{\n  json: {\n    query: `INSERT INTO empresa (nombre_empresa, razon_social, cif, id_tipo_empresa, id_comerciales, activo)\n            VALUES ($1, $2, $3, $4, NULLIF(NULLIF($5::text, ''), 'null')::integer, $6)\n            RETURNING id, nombre_empresa AS nombre, razon_social, cif, id_tipo_empresa, id_comerciales, activo`,\n    param1: data.nombre,\n    param2: data.razonSocial,\n    param3: data.cif,\n    param4: idTipo,\n    param5: idComercial,\n    param6: data.activo,\n  }\n}];"
      },
