    {
      "parameters": {
        "jsCode": "const filters = $input.item.json.body.filters || {};\nconst page = parseInt($input.item.json.body.page) || 1;\nconst limit = 10;\nconst offset = (page - 1) * limit;\nconst conditions = [];\nconst params = [];\nlet paramIndex = 1;\nlet query = `SELECT id, name, surname, email, roleid, enabled, COUNT(*) OVER() as total_count, (SELECT COUNT(*) FROM \"user\") AS stats_total, (SELECT COUNT(*) FROM \"user\" WHERE enabled = true) AS stats_activos, (SELECT COUNT(*) FROM \"user\" WHERE enabled = false) AS stats_inactivos FROM \"user\" WHERE 1=1`;\nif (filters.searchText && typeof filters.searchText === 'string' && filters.searchText.trim() !== '') {\n  conditions.push(`(CONCAT(name, ' ', surname) ILIKE $${paramIndex} OR email ILIKE $${paramIndex})`);\n  params.push(`%${filters.searchText}%`);\n  paramIndex++;\n}\nif (filters.status !== undefined && filters.status !== null && filters.status !== '') {\n  conditions.push(`enabled = $${paramIndex}`);\n  params.push(filters.status);\n  paramIndex++;\n}\nif (filters.roleid !== undefined && filters.roleid !== null && filters.roleid !== '') {\n  conditions.push(`roleid = $${paramIndex}`);\n  params.push(filters.roleid);\n  paramIndex++;\n}\nif (conditions.length > 0) { query += ' AND ' + conditions.join(' AND '); }\nquery += ` ORDER BY id DESC LIMIT ${limit} OFFSET ${offset}`;\nreturn [{ json: { query, params, page, limit } }];"
      },
