                                                           "name":  "Postgres account"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Normaliza el payload de creaciÃƒÂ³n de documento. El front manda `createDocumento` con todo\n// bajo `body.documentoData`; el alta al crear un trabajador manda `uploadDocumento` con los\n// campos planos en `body`. Unificamos ambas formas y convertimos los ids a enteros.\n// Procesa TODOS los items: soporta varios documentos en una misma alta de trabajador.\nconst toInt = (v) =\u003e (v === null || v === undefined || v === \u0027\u0027) ? null : parseInt(v, 10);\nreturn $input.all().map((item) =\u003e {\n  const b = item.json.body || {};\n  const d = b.documentoData || b;\n  return {\n    json: {\n      id_trabajador: toInt(d.id_trabajador ?? d.trabajadorId ?? b.trabajadorId),\n      tipoId: toInt(d.tipoId),\n      descripcion: d.descripcion || \u0027\u0027,\n      requiere_firma: d.requiere_firma === true,\n      fileName: d.fileName || d.nombre || null,\n      base64: d.base64 || \u0027\u0027\n    }\n  };\n});"
                                     },
                      "id":  "48bf43fe-e89e-4c8e-a1dd-2600d78d6fb3",
                      "name":  "JS: Normalizar Create",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       -2688,
                                       2768
                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "-- Alta de documento (archivo subido por el usuario). Inserta documento + su contenido y,\n-- si requiere firma, crea el registro de firma en PENDIENTE_ENVIO (aÃƒÂºn no se envÃƒÂ­a a Sinatura;\n-- eso lo hace el Motor Firmas con la acciÃƒÂ³n enviarFirma).\nWITH nuevo_doc AS (\n  INSERT INTO documento (id_trabajador, id_tipo_documento, nombre_fichero, descripcion, requiere_firma)\n  VALUES ($1, $2, $3, $4, $5)\n  RETURNING id\n),\narchivo AS (\n  INSERT INTO documento_archivo (id_documento, contenido_b64)\n  SELECT id, $6 FROM nuevo_doc\n  RETURNING id_documento\n),\nnueva_firma AS (\n  INSERT INTO firma (id_documento, estado, requiere_firma_rrhh)\n  SELECT id, \u0027PENDIENTE_ENVIO\u0027, $7 FROM nuevo_doc WHERE $5 = true\n  RETURNING id_documento\n)\nSELECT id FROM nuevo_doc;",
                                         "options":  {
                                                         "queryReplacement":  "={{ [$json.id_trabajador, $json.tipoId || null, $json.fileName || \u0027documento.pdf\u0027, $json.descripcion || \u0027\u0027, $json.requiere_firma === true, $json.base64 || \u0027\u0027, false] }}"
                                                     }
                                     },
