                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "-- Actualiza descripciÃƒÂ³n y, opcionalmente, nombre y contenido del archivo.\n-- El reemplazo de archivo solo ocurre si llega base64 (el front lo bloquea si hay firma).\nWITH upd AS (\n  UPDATE documento SET\n    descripcion = COALESCE($2, descripcion),\n    nombre_fichero = CASE WHEN $3 \u003c\u003e \u0027\u0027 THEN $3 ELSE nombre_fichero END,\n    updated_at = NOW()\n  WHERE id = $1\n  RETURNING id\n),\nupd_arch AS (\n  UPDATE documento_archivo SET contenido_b64 = $4, updated_at = NOW()\n  WHERE id_documento = $1 AND $4 \u003c\u003e \u0027\u0027\n  RETURNING id_documento\n)\nSELECT id FROM upd;",
                                         "options":  {
                                                         "queryReplacement":  "={{ [($json.body.documentoData||{}).id, ($json.body.documentoData||{}).descripcion || null, ($json.body.documentoData||{}).fileName || \u0027\u0027, ($json.body.documentoData||{}).base64 || \u0027\u0027] }}"
                                                     }
                                     },
