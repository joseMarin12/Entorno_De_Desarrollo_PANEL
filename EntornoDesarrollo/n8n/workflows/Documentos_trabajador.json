    {
      "parameters": {
        "jsCode": "// Normaliza el payload de creación de documento. El front manda createDocumento con todo\n// bajo body.documentoData; el alta al crear un trabajador manda uploadDocumento con los\n// campos planos en body. Unificamos ambas formas y convertimos los ids a enteros.\n// El base64 puede llegar como Data URL completa (data:mime;base64,xxxx) o ya limpio; se normaliza aquí.\n// Procesa TODOS los items: soporta varios documentos en una misma alta de trabajador.\nconst toInt = (v) => (v === null || v === undefined || v === '') ? null : parseInt(v, 10);\nconst stripDataUrl = (s) => (typeof s === 'string' && s.includes(',')) ? s.split(',').pop() : (s || '');\nreturn $input.all().map((item) => {\n  const b = item.json.body || {};\n  const d = b.documentoData || b;\n  return {\n    json: {\n      id_trabajador: toInt(d.id_trabajador ?? d.trabajadorId ?? b.trabajadorId),\n      tipoId: toInt(d.tipoId),\n      descripcion: d.descripcion || '',\n      requiere_firma: d.requiere_firma === true,\n      fileName: d.fileName || d.nombre || null,\n      base64: stripDataUrl(d.base64 || '')\n    }\n  };\n});"
      },
      "id": "ea04d941-7be6-469d-a3e2-1aaefa477159",
      "name": "JS: Normalizar Create",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        304
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO documentacion (id_trabajador, id_tipodoc, nombre_fichero, doc, descripcion)\nVALUES ($1, $2, $3, decode($4, 'base64'), $5)\nRETURNING id;",
        "options": {
          "queryReplacement": "={{ [$json.id_trabajador, $json.tipoId, $json.fileName, $json.base64, $json.descripcion] }}"
        }
      },
      "id": "6d6a0020-1d8e-4d7c-a4e7-f6ec14706000",
      "name": "SQL: Insert Manual",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        240,
        336
      ],
      "credentials": {
        "postgres": {
          "id": "AUTOPOSTGRESCRED01",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE documentacion SET\n  descripcion = COALESCE($2, descripcion),\n  nombre_fichero = CASE WHEN $3 <> '' THEN $3 ELSE nombre_fichero END,\n  doc = CASE WHEN $4 <> '' THEN decode($4, 'base64') ELSE doc END,\n  updated_at = NOW()\nWHERE id = $1\nRETURNING id;",
        "options": {
          "queryReplacement": "={{ [($json.body.documentoData||{}).id, ($json.body.documentoData||{}).descripcion || null, ($json.body.documentoData||{}).fileName || '', (($json.body.documentoData||{}).base64 || '').includes(',') ? ($json.body.documentoData.base64.split(',').pop()) : (($json.body.documentoData||{}).base64 || '')] }}"
        }
      },
