    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  d.id,\n  d.nombre_fichero,\n  td.tipo AS tipo_nombre,\n  d.id_tipodoc AS tipo_id,\n  d.descripcion,\n  d.created_at AS fecha_creacion,\n  NULL::json AS firma\nFROM documentacion d\nLEFT JOIN tipodoc td ON td.id = d.id_tipodoc\nWHERE d.id_trabajador = $1\nORDER BY d.created_at DESC;",
        "options": {
          "queryReplacement": "={{ [$json.body.trabajadorId] }}"
        }
      },
      "id": "e4c3583e-54de-432b-84f6-7e99ad00e8cc",
      "name": "SQL: Get Documentos",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "alwaysOutputData": true,
      "position": [
        -112,
        16
      ],
