                                   ]
                  },
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT\n  d.id,\n  d.nombre_fichero,\n  td.nombre AS tipo_nombre,\n  d.id_tipo_documento AS tipo_id,\n  d.descripcion,\n  d.created_at AS fecha_creacion,\n  CASE WHEN f.id IS NULL THEN NULL ELSE json_build_object(\n    \u0027id\u0027, f.id,\n    \u0027estado\u0027, f.estado,\n    \u0027fecha_asignacion\u0027, d.created_at,\n    \u0027sinatura_id\u0027, f.sinatura_id,\n    \u0027requiere_firma_rrhh\u0027, f.requiere_firma_rrhh,\n    \u0027email_segundo_firmante\u0027, f.email_segundo_firmante,\n    \u0027motivo\u0027, f.motivo,\n    \u0027fecha_envio\u0027, f.fecha_envio,\n    \u0027fecha_firma_trabajador\u0027, f.fecha_firma_trabajador,\n    \u0027fecha_firma_rrhh\u0027, f.fecha_firma_rrhh,\n    \u0027fecha_completado\u0027, f.fecha_completado\n  ) END AS firma\nFROM documento d\nLEFT JOIN tipo_documento td ON td.id = d.id_tipo_documento\nLEFT JOIN firma f ON f.id_documento = d.id\nWHERE d.id_trabajador = $1 \nORDER BY d.created_at DESC;",
                                         "options":  {
                                                         "queryReplacement":  "={{ [$json.body.trabajadorId] }}"
                                                     }
                                     },
                      "id":  "3710b95a-7a41-443a-9f7e-788d28e651fe",
                      "name":  "SQL: Get Documentos",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.6,
                      "alwaysOutputData":  true,
                      "position":  [
                                       -2720,
                                       2480
                                   ],
                      "credentials":  {
                                          "postgres":  {
