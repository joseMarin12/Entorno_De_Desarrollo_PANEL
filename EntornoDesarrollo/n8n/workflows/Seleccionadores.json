        {
            "parameters": {
                "jsCode": "const body = $input.item.json.body || {};\nconst filters = body.filters || {};\nconst conditions = [];\nconst params = [];\n\nlet query = `\n  SELECT \n    s.*, \n    (CASE WHEN e.id IS NOT NULL THEN json_build_object(\u0027id\u0027, e.id, \u0027nombre\u0027, e.nombre_empresa) ELSE NULL END) as empresa \n  FROM seleccionadores s \n  LEFT JOIN empresa e ON s.id_empresa = e.id \n  WHERE 1=1\n`;\n\n// 1. Filtro de texto dinÃ¡mico parametrizado (CORREGIDO: rim() -\u003e trim() y tipo string)\nif (filters.searchText \u0026\u0026 typeof filters.searchText === \u0027string\u0027 \u0026\u0026 filters.searchText.trim() !== \u0027\u0027) {\n  conditions.push(`(CONCAT(s.nombre, \u0027 \u0027, s.primer_apellido, \u0027 \u0027, COALESCE(s.segundo_apellido,\u0027\u0027)) ILIKE $${params.length + 1} OR s.email ILIKE $${params.length + 1})`);\n  params.push(`%${filters.searchText.trim()}%`);\n}\n\n// 2. Filtro de status dinÃ¡mico parametrizado (CORREGIDO: Manejo del valor del select en Front)\nif (filters.status !== undefined \u0026\u0026 filters.status !== null \u0026\u0026 filters.status !== \u0027\u0027) {\n  const statusStr = String(filters.status).toLowerCase();\n  \n  // Condicional corregido para ignorar si en el select nos mandan \"todos\" o \"todos los estados\"\n  if (statusStr !== \u0027todos\u0027 \u0026\u0026 statusStr !== \u0027todos los estados\u0027) {\n    conditions.push(`s.activo = $${params.length + 1}`);\n    // Solo serÃ¡ true si envÃ­an \u0027activo\u0027 / \u0027activos\u0027, caso contrario (\u0027inactivos\u0027 o \u0027de baja\u0027) enviarÃ¡ false\n    params.push(statusStr === \u0027activos\u0027 || statusStr === \u0027activo\u0027);\n  }\n}\n\n// 3. NUEVO: Filtro de tipo dinÃ¡mico parametrizado (Faltaba incorporar este campo del Frontend)\nif (filters.tipo !== undefined \u0026\u0026 filters.tipo !== null \u0026\u0026 filters.tipo !== \u0027\u0027) {\n  const tipoStr = String(filters.tipo).toLowerCase();\n  \n  // Evitamos filtrar si eligen \"todos o \"todos los tipos\" en el select del form\n  if (tipoStr !== \u0027todos\u0027 \u0026\u0026 tipoStr !== \u0027todos los tipos\u0027) {\n    conditions.push(`s.tipo = $${params.length + 1}`);\n    params.push(tipoStr); // InyectarÃ¡ \u0027interno\u0027 o \u0027externo\u0027 de forma de segura\n  }\n}\n\nif (conditions.length \u003e 0) {\n  query += \u0027 AND \u0027 + conditions.join(\u0027 AND \u0027);\n}\n\nquery += \u0027 ORDER BY s.created_at DESC\u0027;\n\nreturn [{ json: { query: query, params: params } }];\n"
            },
