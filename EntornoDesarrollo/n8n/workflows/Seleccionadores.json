                  {
                      "parameters":  {
                                         "jsCode":  "const body = $input.item.json.body || {};\nconst filters = body.filters || {};\nconst page = body.page || 1;\nconst limit = body.limit || 10;\nconst offset = (page - 1) * limit;\nconst conditions = [];\nconst params = [];\n\nif (filters.searchText \u0026\u0026 typeof filters.searchText === \u0027string\u0027 \u0026\u0026 filters.searchText.trim() !== \u0027\u0027) {\n  conditions.push(`(CONCAT(s.nombre, \u0027 \u0027, s.primer_apellido, \u0027 \u0027, COALESCE(s.segundo_apellido,\u0027\u0027)) ILIKE $${params.length + 1} OR s.email ILIKE $${params.length + 1})`);\n  params.push(`%${filters.searchText.trim()}%`);\n}\n\nif (filters.status !== undefined \u0026\u0026 filters.status !== null \u0026\u0026 filters.status !== \u0027\u0027) {\n  const statusStr = String(filters.status).toLowerCase();\n  if (statusStr !== \u0027todos\u0027 \u0026\u0026 statusStr !== \u0027todos los estados\u0027) {\n    conditions.push(`s.activo = $${params.length + 1}`);\n    params.push(statusStr === \u0027activos\u0027 || statusStr === \u0027activo\u0027);\n  }\n}\n\nif (filters.tipo !== undefined \u0026\u0026 filters.tipo !== null \u0026\u0026 filters.tipo !== \u0027\u0027) {\n  const tipoStr = String(filters.tipo).toLowerCase();\n  if (tipoStr !== \u0027todos\u0027 \u0026\u0026 tipoStr !== \u0027todos los tipos\u0027) {\n    conditions.push(`s.tipo = $${params.length + 1}`);\n    params.push(tipoStr);\n  }\n}\n\nlet whereClause = \u0027WHERE 1=1\u0027;\nif (conditions.length \u003e 0) {\n  whereClause += \u0027 AND \u0027 + conditions.join(\u0027 AND \u0027);\n}\n\nconst limitParam = params.length + 1;\nconst offsetParam = params.length + 2;\nparams.push(limit);\nparams.push(offset);\n\nconst query = `WITH global_stats AS (\n  SELECT\n    COUNT(*)::int as total,\n    COUNT(*) FILTER (WHERE activo = true)::int as activos,\n    COUNT(*) FILTER (WHERE activo = false)::int as inactivos,\n    COUNT(*) FILTER (WHERE tipo = \u0027externo\u0027)::int as externos\n  FROM seleccionadores\n),\nfiltered_data AS (\n  SELECT\n    s.*,\n    (CASE WHEN e.id IS NOT NULL THEN json_build_object(\u0027id\u0027, e.id, \u0027nombre\u0027, e.nombre_empresa) ELSE NULL END) as empresa\n  FROM seleccionadores s\n  LEFT JOIN empresa e ON s.id_empresa = e.id\n  ${whereClause}\n  ORDER BY s.created_at DESC\n  LIMIT $${limitParam} OFFSET $${offsetParam}\n),\nfiltered_count AS (\n  SELECT COUNT(*)::int as total_filtered\n  FROM seleccionadores s\n  ${whereClause}\n)\nSELECT\n  fd.*,\n  fc.total_filtered,\n  gs.total as stats_total,\n  gs.activos as stats_activos,\n  gs.inactivos as stats_inactivos,\n  gs.externos as stats_externos\nFROM global_stats gs\nCROSS JOIN filtered_count fc\nLEFT JOIN filtered_data fd ON true`;\n\nreturn [{ json: { query, params } }];\n"
                                     },
